.env
.env.test
.env.production

# Uploaded KYC/registration documents — sensitive PII, never belongs in git
# history (see server/src/lib/documentEncryption.ts for how these are
# protected at rest on disk instead).
server/uploads/

# Built SPA copied into the server — regenerated from client/dist by the
# Docker build (Dockerfile stage 1), never served from the repo copy.
server/public/

# One-off local verification scripts
server/scratch-*.ts

