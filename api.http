@baseUrl = http://localhost:3000/api
@orderId = 526501c0-42a1-4ef4-8106-414eb6051b96

### ==========================================================
### 1. LOGIN — Super Admin
### ==========================================================
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "superadmin@parcelmoover.com",
  "password": "DemoPass123!"
}

### ==========================================================
### 2. GET /me — Check logged-in user
### ==========================================================
GET http://localhost:3000/me
Cookie: accessToken={{login.response.cookies.accessToken}}

### ==========================================================
### 3. REGISTER USER (Admin / Vendor / Rider)
### ==========================================================
POST {{baseUrl}}/auth/users/register
Content-Type: application/json
X-CSRF-Token: {{login.response.body.csrfToken}}
Cookie: accessToken={{login.response.cookies.accessToken}}; csrfToken={{login.response.body.csrfToken}}

{
  "type": "admin",
  "fullName": "Anil Thakur",
  "email": "adminAnil@parcelmoover.com",
  "password": "test123!",
  "phone": "9800600010",
  "position": "Branch Manager"
}

### ==========================================================
### 4. CREATE ORDER
### ==========================================================
POST {{baseUrl}}/orders
Content-Type: application/json
Idempotency-Key: 590e8400-e29b-41d4-a716-447655440000
X-CSRF-Token: {{login.response.body.csrfToken}}
Cookie: accessToken={{login.response.cookies.accessToken}}; csrfToken={{login.response.body.csrfToken}}

{
  "sender": {
    "name": "Bahadur",
    "phone": "9800000001",
    "email": "ram@example.com",
    "address": "Kathmandu",
    "locationId": "11111111-0000-0000-0000-000000000001"
  },
  "receiver": {
    "name": "Shyam Lama",
    "phone": "9800000002",
    "email": "shyam@example.com",
    "address": "Pokhara",
    "locationId": "11111111-0000-0000-0000-000000000002"
  },
  "originLocationId": "11111111-0000-0000-0000-000000000001",
  "destinationLocationId": "11111111-0000-0000-0000-000000000002",
  "orderType": "delivery",
  "serviceType": "dtd",
  "pieces": 2,
  "weightKg": 5.5,
  "codAmount": 2500,
  "deliveryCharge": 150,
  "pickupAddress": "New Baneshwor, Kathmandu",
  "scheduledPickupAt": "2026-06-20T10:00:00.000Z",
  "vendorId": "55555555-0000-0000-0000-000000000001"
}

### ==========================================================
### 5. UPDATE ORDER STATUS
### ==========================================================
PATCH {{baseUrl}}/orders/{{orderId}}/status
Content-Type: application/json
X-CSRF-Token: {{login.response.body.csrfToken}}
Cookie: accessToken={{login.response.cookies.accessToken}}; csrfToken={{login.response.body.csrfToken}}

{
  "status": "rider_assigned",
  "remarks": "Rider assigned for pickup"
}