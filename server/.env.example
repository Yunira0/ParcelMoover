# Copy this file to .env and fill in real values. .env is gitignored.

# Required — server refuses to start without these.
JWT_SECRET=replace-with-a-long-random-string
DATABASE_URL=postgresql://user:password@localhost:5432/parcelmoover
# Signs the double-submit CSRF token (see middlewares/csrf.middleware.ts).
# Use a different long random string than JWT_SECRET.
CSRF_SECRET=replace-with-a-different-long-random-string
# AES-256 key (32 bytes, hex-encoded = 64 hex chars) that encrypts KYC/registration
# documents at rest (see lib/documentEncryption.ts). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Losing this key makes every previously-uploaded document unreadable - back it up
# outside the app server, and never commit it.
DOCUMENT_ENCRYPTION_KEY=replace-with-a-64-character-hex-string

# development | production — gates cookie secure flags, error verbosity,
# and dev-only routes (e.g. POST /api/auth/test-email). Set to "production"
# in any real deployment.
NODE_ENV=development

# Optional — sensible defaults apply if omitted.
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173
# Postgres pool size (server/src/lib/prisma.ts), per process. Default 60 -
# check Postgres's own max_connections before raising this in production,
# and divide across instances if running more than one.
DB_POOL_MAX=60

# Optional — used by `npx prisma db seed` to set the super admin's email
# instead of the built-in demo default (admin@parcelmoover.com).
SUPERADMIN_EMAIL=

# Redis is optional in development: the app falls back to in-memory rate
# limiting/caching if it's unreachable. Only needed for production-like
# multi-instance behavior.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Trust a reverse proxy's X-Forwarded-* headers (set TRUE only in production
# behind a known proxy, e.g. nginx/Cloudflare).
TRUST_PROXY=false
TRUSTED_PROXIES=

# Public app URL, used in emails/links.
APP_URL=http://localhost:5173

# SMTP is optional — without it, welcome/notification emails are skipped
# (logged, not sent) instead of failing.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# NCM (Nepal Can Move) — outside-valley carrier. Docs: .claude/skills/ncm-api
# Local dev points at the mock (node ncm-mock/server.js). For production, get
# the real host + vendor token from NCM IT Admin (IT@nepalcanmove.com).
NCM_BASE_URL=http://localhost:4100
NCM_API_TOKEN=test-ncm-token
# Secret path segment for the inbound webhook (NCM sends no HMAC signature).
NCM_WEBHOOK_SECRET=replace-with-a-long-random-string
# Our hub branch name in NCM's system (fbranch on order create).
NCM_FROM_BRANCH=TINKUNE
# Our OWN public URL, so NCM knows where to send status webhooks. Re-asserted
# automatically before every handoff. Defaults to http://localhost:$PORT if
# unset (fine for the mock); production must set a real public HTTPS URL.
NCM_WEBHOOK_BASE_URL=http://localhost:3000

# Outbound vendor webhooks (Partner API v1, /api/webhooks). 32-byte key, base64
# encoded, used to encrypt endpoint signing secrets at rest (AES-256-GCM).
# Generate with: openssl rand -base64 32
WEBHOOK_SECRET_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key
