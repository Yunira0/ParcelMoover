# Copy this file to .env and fill in real values. .env is gitignored.

# Required — server refuses to start without these.
JWT_SECRET=replace-with-a-long-random-string
DATABASE_URL=postgresql://user:password@localhost:5432/parcelmoover

# Optional — sensible defaults apply if omitted.
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173

# Redis is optional in development: the app falls back to in-memory rate
# limiting/caching if it's unreachable. Only needed for production-like
# multi-instance behavior.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Trust a reverse proxy's X-Forwarded-* headers (set TRUE only in production
# behind a known proxy, e.g. nginx/Cloudflare).
TRUST_PROXY=false
TRUSTED_PROXIES=

# Public app URL, used in emails/links.
APP_URL=http://localhost:5173

# SMTP is optional — without it, welcome/notification emails are skipped
# (logged, not sent) instead of failing.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
